# Input data
VCF_GZ=./data/raw/1001G.Chr4.vcf.gz
PHENO_SOURCE_CSV=./data/raw/values.csv
PHENO_FILE=./data/processed/asia.pheno.txt
KEEP_IDS_FILE=./data/processed/asia.keep_ids.txt

# Phenotype format written by scripts/00_build_subset_inputs.py:
# FID IID PHENO
PHENO_NAME=PHENO

# Sample subset
SUBSET_NAME=asia
RUN_LABEL=asia
SUBSET_COUNTRIES=Azerbaijan,Armenia,Georgia,Kyrgyzstan,Uzbekistan,Japan,India,Afghanistan,China,Iran,Kazakhstan,Tajikistan,Lebanon

# Region and filtering
CHR=4
MAF=0.05
GENO_MISSING=0.05
NUM_PCS=5

# Optional machine-local overrides can live in config/project.env.local

# Tool binaries
BCFTOOLS=bcftools
PLINK2=plink2
GEMMA=gemma
GCTA=gcta64

# Working directories (relative to repo root)
RAW_DIR=data/raw
PROC_DIR=data/processed
RESULTS_DIR=results
