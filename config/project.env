# Input data
VCF_GZ=./data/raw/1001G.Chr4.vcf.gz
PHENO_FILE=./data/processed/pheno.txt

# Phenotype format: two columns with header: IID PHENO
PHENO_NAME=PHENO

# Region and filtering
CHR=4
MAF=0.05
GENO_MISSING=0.05
NUM_PCS=5

# Tool binaries
BCFTOOLS=bcftools
PLINK2=plink2
GEMMA=gemma
GCTA=gcta64

# Working directories (relative to repo root)
RAW_DIR=data/raw
PROC_DIR=data/processed
RESULTS_DIR=results
