# Input data (.vcf or .vcf.gz)
VCF_GZ=./data/raw/1001G.Chr4.vcf
PHENO_SOURCE_CSV=./data/raw/values.csv
PHENO_FILE=./data/processed/spain.pheno.txt
KEEP_IDS_FILE=./data/processed/spain.keep_ids.txt

# Phenotype format written by scripts/00_build_subset_inputs.py:
# FID IID PHENO
PHENO_NAME=PHENO

# Sample subset
SUBSET_NAME=spain
RUN_LABEL=spain
SUBSET_COUNTRIES=Spain

# Region and filtering
CHR=4
MAF=0.05
GENO_MISSING=0.05
NUM_PCS=5
NEW_ID_MAX_ALLELE_LEN=40
MAX_ALLELES=2

# Optional machine-local overrides can live in config/project.env.local

# Tool binaries
BCFTOOLS=bcftools
PLINK2=plink2
GEMMA=gemma
GCTA=gcta64

# Working directories (relative to repo root)
RAW_DIR=data/raw
PROC_DIR=data/processed
RESULTS_DIR=results
